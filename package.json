{
  "name": "@myceliuminc/outfit",
  "version": "0.1.3",
  "description": "Portable, enforced agent personas. One spec - any runtime.",
  "license": "MIT",
  "author": "MyceliumInc",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MyceliumInc/Outfits.git"
  },
  "homepage": "https://github.com/MyceliumInc/Outfits#readme",
  "bugs": "https://github.com/MyceliumInc/Outfits/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "outfit": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "examples",
    "schema",
    "templates",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "prebuild": "npm run clean",
    "build": "tsc",
    "postbuild": "chmod +x dist/cli/index.js",
    "dev": "tsc -w",
    "test": "node --test",
    "pretest": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "agent",
    "ai",
    "mcp",
    "claude",
    "llm",
    "persona",
    "skills"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "minimatch": "^10.0.1",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "typescript": "^5.6.0"
  }
}
